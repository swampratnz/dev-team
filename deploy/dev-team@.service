# Templated oneshot unit for running a dev-team job on an Ubuntu host.
#
#   sudo cp deploy/dev-team@.service /etc/systemd/system/
#   sudo systemctl start dev-team@<jobname>.service
#
# Each instance reads /etc/dev-team/<jobname>.env, which must define
# DEV_TEAM_TITLE and DEV_TEAM_DESCRIPTION, plus credentials: either
# CLAUDE_CODE_OAUTH_TOKEN (Claude subscription, from `claude setup-token`)
# or ANTHROPIC_API_KEY (Claude API). DEV_TEAM_ARGS is optional.
[Unit]
Description=dev-team job %i (multi-agent development run)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=devteam
Group=devteam
WorkingDirectory=/opt/dev-team
EnvironmentFile=/etc/dev-team/%i.env
ExecStart=/opt/dev-team/.venv/bin/dev-team "${DEV_TEAM_TITLE}" "${DEV_TEAM_DESCRIPTION}" $DEV_TEAM_ARGS

# Hardening.
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/opt/dev-team
ProtectControlGroups=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
ProtectKernelLogs=yes
ProtectHostname=yes
ProtectClock=yes
RestrictSUIDSGID=yes
RestrictRealtime=yes
RemoveIPC=yes
LockPersonality=yes
SystemCallArchitectures=native
# A job may use the in-process container sandbox (--sandbox, rootless
# podman/docker), which needs user namespaces and clone/mount syscalls, so the
# namespace/capability/syscall filters are intentionally omitted. If this host
# never uses --sandbox, run the whole process in an outer container/VM instead
# (see DEPLOYMENT.md 5d) — that is what contains the engineer's own tool loop.

[Install]
WantedBy=multi-user.target
